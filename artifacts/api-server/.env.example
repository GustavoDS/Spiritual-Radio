# =============================================================================
# Rádio Espiritual Inteligente — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================================================

# Ambiente (development | production | test)
NODE_ENV=development

# Porta do servidor (definida automaticamente pelo Replit em produção)
PORT=3000

# =============================================================================
# Banco de dados (PostgreSQL) — obrigatório
# =============================================================================
DATABASE_URL=postgresql://usuario:senha@localhost:5432/radio_espiritual

# =============================================================================
# Autenticação JWT — obrigatório
# =============================================================================
# Gere com: openssl rand -base64 64
JWT_SECRET=troque-por-uma-chave-secreta-longa-e-aleatoria

# Tempo de expiração do token (ex: 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# =============================================================================
# Redis — opcional (filas BullMQ ficam indisponíveis sem Redis)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# CORS — origens permitidas
# Use * para permitir qualquer origem (não recomendado em produção)
# Para múltiplas origens, separe por vírgula:
# CORS_ORIGINS=https://meuapp.com,https://admin.meuapp.com
# =============================================================================
CORS_ORIGINS=*

# =============================================================================
# Rate Limiting
# =============================================================================
# Janela de tempo em milissegundos (padrão: 60000 = 1 minuto)
RATE_LIMIT_WINDOW_MS=60000

# Máximo de requisições por janela para rotas gerais (padrão: 100)
RATE_LIMIT_MAX=100

# Máximo de requisições por janela para rotas de autenticação (padrão: 20)
RATE_LIMIT_AUTH_MAX=20

# =============================================================================
# Upload de arquivos
# =============================================================================
# Diretório de uploads (padrão: uploads/)
UPLOAD_DIR=uploads

# Tamanho máximo de arquivo de áudio em MB (padrão: 50)
MAX_FILE_SIZE_MB=50

# =============================================================================
# Logging
# =============================================================================
# Nível de log (error | warn | info | http | debug)
LOG_LEVEL=info

# =============================================================================
# Sessão (Express Session)
# =============================================================================
# Gere com: openssl rand -base64 32
SESSION_SECRET=troque-por-um-secret-de-sessao-seguro
