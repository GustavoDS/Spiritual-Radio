# =============================================================================
# Rádio Espiritual Inteligente — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================================================

# Ambiente (development | production | test)
NODE_ENV=development

# Porta do servidor (definida automaticamente pelo Replit em produção)
PORT=3000

# =============================================================================
# Banco de dados (PostgreSQL) — obrigatório
# =============================================================================
DATABASE_URL=postgresql://radio_espiritual:D6d3h7g707@localhost:5432/radio_espiritual

# =============================================================================
# Autenticação JWT — obrigatório
# =============================================================================
# Gere com: openssl rand -base64 64
JWT_SECRET=98596eb54e26ffeb3f488c9aa90bf9b1dfc4e65982557c022cccbec99b9b0310297d7b63186f48960b6ef4c2b512eaeedceb915e447db2fcf10006196291d33c

# Tempo de expiração do token de acesso (ex: 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# Secret separado para refresh tokens (gere com: openssl rand -base64 64)
JWT_REFRESH_SECRET=eb7362e36909e953a7ce0b2305a9e3c1245636752cc501220a9019c2107ee45f0395381def924ef61d57097b0921683e24ec70d8bbf9b797c0a55ee2a279d960

# =============================================================================
# Redis — opcional (filas BullMQ ficam indisponíveis sem Redis)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Inteligência Artificial — obrigatório para geração de conteúdo
# =============================================================================
#
# Provedor de IA:
#   openai      → OpenAI (ChatGPT)          https://platform.openai.com/api-keys
#   anthropic   → Anthropic (Claude)        https://console.anthropic.com/
#   gemini      → Google Gemini             https://aistudio.google.com/apikey
#   openrouter  → OpenRouter (multi-model)  https://openrouter.ai/keys
#
AI_PROVIDER=openai

# Chave de API do provedor escolhido
AI_API_KEY=sk-...

# Modelo a usar (deixe vazio para usar o padrão do provedor)
#   openai:     gpt-4o-mini (padrão) | gpt-4o | gpt-4-turbo
#   anthropic:  claude-3-5-haiku-20241022 (padrão) | claude-3-5-sonnet-20241022
#   gemini:     gemini-1.5-flash (padrão) | gemini-1.5-pro
#   openrouter: openai/gpt-4o-mini (padrão) | anthropic/claude-3-5-sonnet | google/gemini-flash-1.5
AI_MODEL=

# =============================================================================
# Síntese de Voz (TTS) — obrigatório para gerar áudio
# =============================================================================
#
# Provedor TTS:
#   openai      → OpenAI TTS (usa mesma chave do AI_API_KEY se igual)   https://platform.openai.com/api-keys
#   elevenlabs  → ElevenLabs (alta qualidade, suporta português)         https://elevenlabs.io/
#
TTS_PROVIDER=openai

# Chave de API do provedor TTS (pode ser diferente de AI_API_KEY)
TTS_API_KEY=sk-...

# Modelo TTS (deixe vazio para usar o padrão do provedor)
#   openai:     tts-1 (padrão, mais rápido) | tts-1-hd (maior qualidade)
#   elevenlabs: eleven_multilingual_v2 (padrão) | eleven_turbo_v2_5
TTS_MODEL=
#
# === Como configurar vozes no banco de dados ===
#
# Cada registro na tabela "voices" representa uma voz disponível.
# Cada registro na tabela "voices" possui dois campos de identificação:
#   nome           → Nome de exibição (qualquer texto amigável)
#   voice_id_externo → ID técnico enviado ao provider TTS
#
#   Provider openai:
#     voice_id_externo deve ser: alloy, ash, coral, echo, fable, nova, onyx, sage, shimmer
#     Se omitido, usa o campo "nome" como fallback.
#
#   Provider elevenlabs:
#     voice_id_externo deve ser o voice_id da ElevenLabs:
#     Ex: "21m00Tcm4TlvDq8ikWAM" (Rachel) | "AZnzlk1XvdvUeBnXmlld" (Domi)
#     Consulte: https://elevenlabs.io/app/voice-library
#
# O campo "provider" na voz define qual provedor usar para aquela voz específica.

# =============================================================================
# CORS — origens permitidas
# Use * para permitir qualquer origem (não recomendado em produção)
# Para múltiplas origens, separe por vírgula:
# CORS_ORIGINS=https://meuapp.com,https://admin.meuapp.com
# =============================================================================
CORS_ORIGINS=*

# =============================================================================
# Rate Limiting
# =============================================================================
# Janela de tempo em milissegundos (padrão: 60000 = 1 minuto)
RATE_LIMIT_WINDOW_MS=60000

# Máximo de requisições por janela para rotas gerais (padrão: 100)
RATE_LIMIT_MAX=100

# Máximo de requisições por janela para rotas de autenticação (padrão: 20)
RATE_LIMIT_AUTH_MAX=20

# =============================================================================
# Storage de mídia
# =============================================================================
#
# Provedor de storage:
#   local  → disco local, servido via Express static (padrão, desenvolvimento)
#   s3     → AWS S3
#   r2     → Cloudflare R2 (S3-compatible, recomendado para produção)
#
STORAGE_PROVIDER=local

# --- Cloudflare R2 (recomendado para produção) ----------------------------
# Account ID: Cloudflare Dashboard → aba direita → Account ID
# R2_ACCOUNT_ID=abc123def456
# R2_ACCESS_KEY_ID=<chave R2 em Manage R2 API Tokens>
# R2_SECRET_ACCESS_KEY=<secret R2>
# R2_BUCKET=radio-espiritual
# URL pública do bucket (domínio custom ou r2.dev):
# R2_PUBLIC_URL=https://cdn.meudominio.com
# R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# --- AWS S3 ---------------------------------------------------------------
# S3_REGION=us-east-1
# S3_BUCKET=radio-espiritual
# S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# --- Storage local (apenas quando STORAGE_PROVIDER=local) -----------------
# Diretório de uploads (padrão: uploads/)
UPLOAD_DIR=uploads

# Tamanho máximo de arquivo de áudio em MB (padrão: 50)
MAX_FILE_SIZE_MB=50

# =============================================================================
# Logging
# =============================================================================
# Nível de log (error | warn | info | http | debug)
LOG_LEVEL=info

# =============================================================================
# Rádio — Canal padrão
# =============================================================================
# ID do canal padrão usado pelo RadioService quando channel_id não é informado
DEFAULT_CHANNEL_ID=1

# =============================================================================
# Sync de banco (desenvolvimento)
# =============================================================================
# Em produção, defina SYNC_DB=false e execute as migrations manualmente:
#   node -e "import('./src/migrations/runner.js').then(m => m.runMigrations())"
# Em desenvolvimento, SYNC_DB=true aplica alter automático no schema
SYNC_DB=true

# =============================================================================
# Sessão (Express Session)
# =============================================================================
# Gere com: openssl rand -base64 32
SESSION_SECRET=eb7362e36909e953a7ce0b2305a9e3c1245636752cc501220a9019c2107ee45f0395381def924ef61d57097b0921683e24ec70d8bbf9b797c0a55ee2a279d960
