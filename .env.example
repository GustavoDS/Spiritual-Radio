# Server
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/radio_espiritual

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
SESSION_SECRET=your-session-secret-change-in-production

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# AI / Voice Services (configure conforme provider)
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_TTS_API_KEY=
